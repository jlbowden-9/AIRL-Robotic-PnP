<?xml version="1.0"?>

<robot name="Pallet">
<!-------------------------------------- Base Link -------------------------------------->
  <link name="base_link">
    <inertial>
      <mass value="500.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1.0" ixy="0.2" ixz="0.2" iyy="1.0" iyz="0.2" izz="1.0"/>
    </inertial>
    <visual>
      <origin rpy="1.57 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="Meshes/PalletTray.STL"/>
      </geometry>
      <material name="PalletTray">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="1.57 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="Meshes/PalletTray.STL"/>
      </geometry>
    </collision>
  </link>

  </robot>