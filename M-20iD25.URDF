  <joint name="BaseJoint" type="fixed">
    <origin rpy="0 0 1.5708" xyz="0.17145 -0.27623 0.7747"/>
    <parent link="base_link"/>
    <child link="RobotBase"/>
  </joint>

  <joint name="Shoulder_Joint" type="revolute">
    <origin rpy="0 0 0" xyz="0.27534 0.16999 0.15701"/>
    <parent link="RobotBase"/>
    <child link="Shoulder"/>
    <axis xyz="0 0 1"/>
    <limit effort="3000" velocity="10.0" lower="-2.965" upper="2.965"/>
     <dynamics damping=".2" friction=".2"/>
  </joint>

  <joint name="UpperArm_Joint" type="revolute">
    <origin rpy="0 0 0" xyz="0.07493 -0.08509 0.26797"/>
    <parent link="Shoulder"/>
    <child link="UpperArm"/>
    <axis xyz="0 1 0"/>
    <limit effort="3000" velocity="10.0" lower="-2.27" upper="2.27"/>
    <dynamics damping=".2" friction=".2"/>
  </joint>

