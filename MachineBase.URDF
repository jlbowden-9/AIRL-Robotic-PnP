<?xml version="1.0"?>

<robot name="MachineBase">
  <!-------------------------------------- Base Link -------------------------------------->
  <inertial>
    <mass value="500.0"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <inertia ixx="1.0" ixy="0.2" ixz="0.2" iyy="1.0" iyz="0.2" izz="1.0"/>
  </inertial>

  <link name="base_link">
    <visual>
      <origin rpy="1.57 0 -2.1" xyz="0 0 0"/>
      <geometry>
        <mesh filename="Meshes/DialMachine.STL" scale="0.0254 0.0254 0.0254"/>
      </geometry>
      <material name="MachineBase">
        <color rgba=".18 .18 .18 .7"/>
      </material>
    </visual>


  </link>
</robot>
